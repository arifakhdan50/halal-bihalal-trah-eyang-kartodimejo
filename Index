<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Undangan Halal Bihalal</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Poppins',sans-serif;background:#000;color:white;overflow-x:hidden}
canvas{position:fixed;top:0;left:0;z-index:-1}

/* OPENING */
.opening{
position:fixed;width:100%;height:100vh;
background:linear-gradient(135deg,#052e16,#000,#064e3b);
display:flex;flex-direction:column;justify-content:center;align-items:center;
z-index:9999;text-align:center;padding:20px;
}
.opening h1{
font-family:'Playfair Display',serif;
font-size:clamp(34px,6vw,60px);
color:#facc15;margin-bottom:10px;
text-shadow:0 0 25px rgba(250,204,21,.6);
}
.opening button{
margin-top:20px;background:linear-gradient(45deg,#facc15,#eab308);
border:none;padding:15px 40px;border-radius:40px;font-weight:600;
cursor:pointer;color:#000;font-size:16px;
box-shadow:0 0 25px rgba(250,204,21,.8);
}

/* HERO */
.hero{min-height:100vh;display:flex;justify-content:center;align-items:center;text-align:center;padding:60px 20px}
.hero h2{font-family:'Playfair Display',serif;font-size:clamp(28px,6vw,48px);color:#facc15;margin-bottom:20px}
.hero p{max-width:800px;line-height:1.8;font-size:clamp(14px,3.5vw,17px);opacity:.9}

/* SECTION */
.section{padding:80px 20px;text-align:center}
.card{
max-width:900px;margin:auto;background:rgba(255,255,255,0.05);
backdrop-filter:blur(12px);padding:40px;border-radius:30px;
border:1px solid rgba(250,204,21,0.4);box-shadow:0 30px 80px rgba(0,0,0,.5)
}
.card h2{font-family:'Playfair Display',serif;color:#facc15;margin:20px 0}
.info{margin:8px 0}
.highlight{color:#facc15;font-weight:600}

/* COUNTDOWN */
.countdown-wrapper{display:flex;justify-content:center;gap:10px;margin-top:30px}
.time-box{
background:rgba(250,204,21,0.1);border:1px solid rgba(250,204,21,0.5);
padding:10px 12px;border-radius:12px;min-width:70px
}
.time-box span{display:block;font-size:18px;font-weight:700;color:#facc15}
.time-box small{font-size:11px;opacity:.7}

.footer{padding:80px 20px;text-align:center;background:linear-gradient(#000,#111)}
</style>
</head>
<body>

<canvas id="bgCanvas"></canvas>

<div class="opening" id="opening">
<h1>Undangan</h1>
<h1>Halal Bihalal</h1>
<button onclick="startExperience()">Buka Undangan</button>
</div>

<audio id="music" loop>
<source src="videoplayback.m4a" type="audio/mp4">
</audio>

<section class="hero">
<div>
<h2>Assalamualaikum Warahmatullahi Wabarakatuh</h2>
<p>
Dengan penuh rasa syukur, kami mengharapkan kehadiran seluruh
anggota keluarga besar Trah Eyang Kartodimedjo
dalam acara Halal Bihalal sebagai momen mempererat
silaturahmi dan kebersamaan.
</p>
</div>
</section>

<section class="section">
<div class="card">

<h2>Detail Acara</h2>
<p class="info">📅 Ahad, 22 Maret 2026</p>
<p class="info">🕘 09.00 – 14.00 WIB</p>
<p class="info">📍 Rumah Bp. Hadi Suharto (Alm)</p>
<p class="info">Kluyon, Waru Baki, Sukoharjo</p>

<h2>Acara</h2>
<p class="info">Halal Bihalal Keluarga Besar</p>
<p class="info highlight">Trah Kartodimedjo</p>

<div class="countdown-wrapper">
<div class="time-box"><span id="days">0</span><small>Hari</small></div>
<div class="time-box"><span id="hours">0</span><small>Jam</small></div>
<div class="time-box"><span id="minutes">0</span><small>Menit</small></div>
<div class="time-box"><span id="seconds">0</span><small>Detik</small></div>
</div>

</div>
</section>

<section class="footer">
<h2>Wassalamualaikum Warahmatullahi Wabarakatuh</h2>
<p style="opacity:.7;margin-top:10px">Terima kasih atas perhatian dan kehadirannya</p>
</section>

<script>
const music=document.getElementById("music");
music.volume=0.6;

function startExperience(){
document.getElementById("opening").style.display="none";
music.play();
}

const target=new Date("March 22, 2026 09:00:00").getTime();

setInterval(()=>{
const now=new Date().getTime();
const diff=target-now;
if(diff>0){
days.innerText=Math.floor(diff/(1000*60*60*24));
hours.innerText=Math.floor((diff%(1000*60*60*24))/(1000*60*60));
minutes.innerText=Math.floor((diff%(1000*60*60))/(1000*60));
seconds.innerText=Math.floor((diff%(1000*60))/1000);
}
},1000);

/* PARTICLES */
const canvas=document.getElementById("bgCanvas");
const ctx=canvas.getContext("2d");
function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;}
resize();window.addEventListener("resize",resize);
let particles=[];
for(let i=0;i<120;i++){
particles.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,size:Math.random()*3+1,speed:Math.random()*1+0.5});
}
function animate(){
ctx.clearRect(0,0,canvas.width,canvas.height);
particles.forEach(p=>{
ctx.beginPath();
ctx.arc(p.x,p.y,p.size,0,Math.PI*2);
ctx.fillStyle="rgba(250,204,21,0.8)";
ctx.fill();
p.y+=p.speed;
if(p.y>canvas.height){p.y=0;p.x=Math.random()*canvas.width;}
});
requestAnimationFrame(animate);
}
animate();
</script>

</body>
</html>
